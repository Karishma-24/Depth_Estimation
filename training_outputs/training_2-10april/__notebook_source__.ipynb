#Cell 13 - Improved Training with edge-Aware gradient loss

def gradient_loss(pred, target):
    """
    Penalizes differences in depth gradients (edges).
    Forces the model to preserve sharp boundaries between objects.
    Uses Sobel-style finite differences.
    """
    # Horizontal and vertical gradients of prediction
    pred_dx  = pred[:, :, :, 1:] - pred[:, :, :, :-1]   # [B,1,H,W-1]
    pred_dy  = pred[:, :, 1:, :] - pred[:, :, :-1, :]   # [B,1,H-1,W]

    # Horizontal and vertical gradients of ground truth
    target_dx = target[:, :, :, 1:] - target[:, :, :, :-1]
    target_dy = target[:, :, 1:, :] - target[:, :, :-1, :]

    # L1 on gradient differences
    loss_dx = F.l1_loss(pred_dx, target_dx)
    loss_dy = F.l1_loss(pred_dy, target_dy)

    return loss_dx + loss_dy


def improved_depth_loss(pred, target, alpha=0.85, beta=0.1):
    """
    Combined loss:
      alpha * SSIM         → structural similarity
      (1-alpha) * L1       → absolute depth accuracy
      beta * gradient loss → sharp edges
    """
    l_ssim = ssim_loss(pred, target)
    l_l1   = F.l1_loss(pred, target)
    l_grad = gradient_loss(pred, target)
    return alpha * l_ssim + (1 - alpha) * l_l1 + beta * l_grad


#Cell 14 - retraining with improvements

def train_model_v2(train_loader, test_loader,
                   num_epochs=20, lr=1e-4,
                   save_path="/kaggle/working/best_depth_model_v2.pth"):

    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"Training on: {device}")
    print(f"Train batches per epoch: {len(train_loader)}")

    model     = DepthEstimationUNet().to(device)
    optimizer = Adam(model.parameters(), lr=lr, weight_decay=1e-5)  # weight_decay added
    scheduler = ReduceLROnPlateau(optimizer, mode='min', patience=3, factor=0.5)

    best_val_loss = float('inf')
    history = {'train_loss': [], 'val_loss': []}

    for epoch in range(num_epochs):

        # ── Train ──────────────────────────────────────────────────────────
        model.train()
        train_loss = 0.0

        for batch_idx, (images, depths) in enumerate(train_loader):
            images, depths = images.to(device), depths.to(device)
            optimizer.zero_grad()
            preds = model(images)
            loss  = improved_depth_loss(preds, depths)   # ← uses new loss
            loss.backward()
            optimizer.step()
            train_loss += loss.item()

            if (batch_idx + 1) % 50 == 0:
                print(f"  E{epoch+1} | Batch {batch_idx+1}/{len(train_loader)} "
                      f"| loss={loss.item():.4f}")

        avg_train = train_loss / len(train_loader)

        # ── Validate ───────────────────────────────────────────────────────
        model.eval()
        val_loss = 0.0
        with torch.no_grad():
            for images, depths in test_loader:
                images, depths = images.to(device), depths.to(device)
                val_loss += improved_depth_loss(model(images), depths).item()
        avg_val = val_loss / len(test_loader)

        scheduler.step(avg_val)
        history['train_loss'].append(avg_train)
        history['val_loss'].append(avg_val)

        print(f"\nEpoch {epoch+1}/{num_epochs} | "
              f"Train Loss: {avg_train:.4f} | Val Loss: {avg_val:.4f}")

        if avg_val < best_val_loss:
            best_val_loss = avg_val
            torch.save({
                'epoch': epoch+1,
                'model_state_dict':     model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'val_loss': best_val_loss,
            }, save_path)
            print(f"  ✓ Best model saved (val={best_val_loss:.4f})")

        print("-" * 55)

    return model, history

model_v2, history_v2 = train_model_v2(train_loader, test_loader, num_epochs=20)


