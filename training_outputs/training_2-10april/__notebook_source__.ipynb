#Model

class EncoderBlock(nn.Module):
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.block = nn.Sequential(
            nn.Conv2d(in_channels, out_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True),
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True)
        )
    def forward(self, x):
        return self.block(x)

class DecoderBlock(nn.Module):
    def __init__(self, in_channels, skip_channels, out_channels):
        super().__init__()
        self.block = nn.Sequential(
            nn.Conv2d(in_channels + skip_channels, out_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True),
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True)
        )
    def forward(self, x, skip):
        x = F.interpolate(x, scale_factor=2, mode='bilinear', align_corners=False)
        x = torch.cat([x, skip], dim=1)
        return self.block(x)

class DepthEstimationUNet(nn.Module):
    def __init__(self):
        super().__init__()
        self.enc1        = EncoderBlock(3, 64)
        self.enc2        = EncoderBlock(64, 128)
        self.pool        = nn.MaxPool2d(2, 2)
        self.bottleneck  = EncoderBlock(128, 256)
        self.dec2        = DecoderBlock(256, 128, 128)
        self.dec1        = DecoderBlock(128, 64, 64)
        self.output_conv = nn.Conv2d(64, 1, kernel_size=1)

    def forward(self, x):
        skip1 = self.enc1(x)
        x     = self.pool(skip1)
        skip2 = self.enc2(x)
        x     = self.pool(skip2)
        x     = self.bottleneck(x)
        x     = self.dec2(x, skip2)
        x     = self.dec1(x, skip1)
        return torch.sigmoid(self.output_conv(x))


#Loss function

def ssim_loss(pred, target, window_size=11):
    C1, C2 = 0.01**2, 0.03**2
    mu_p  = F.avg_pool2d(pred,   window_size, 1, window_size//2)
    mu_t  = F.avg_pool2d(target, window_size, 1, window_size//2)
    mu_p2 = mu_p**2; mu_t2 = mu_t**2; mu_pt = mu_p * mu_t
    sp  = F.avg_pool2d(pred**2,     window_size, 1, window_size//2) - mu_p2
    st  = F.avg_pool2d(target**2,   window_size, 1, window_size//2) - mu_t2
    spt = F.avg_pool2d(pred*target, window_size, 1, window_size//2) - mu_pt
    ssim = ((2*mu_pt+C1)*(2*spt+C2)) / ((mu_p2+mu_t2+C1)*(sp+st+C2))
    return torch.clamp((1-ssim)/2, 0, 1).mean()

def depth_loss(pred, target, alpha=0.85):
    return alpha * ssim_loss(pred, target) + (1-alpha) * F.l1_loss(pred, target)


#Training loop
def train_model(train_loader, test_loader,
                num_epochs=20, lr=1e-4,
                save_path="/kaggle/working/best_depth_model.pth"):

    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"Training on: {device}")
    print(f"Train batches per epoch: {len(train_loader)}")

    model     = DepthEstimationUNet().to(device)
    optimizer = Adam(model.parameters(), lr=lr)
    # verbose removed — caused TypeError in newer PyTorch
    scheduler = ReduceLROnPlateau(optimizer, mode='min', patience=3, factor=0.5)

    best_val_loss = float('inf')
    history = {'train_loss': [], 'val_loss': []}

    for epoch in range(num_epochs):

        # ── Train ──────────────────────────────────────────────────────────
        model.train()
        train_loss = 0.0

        for batch_idx, (images, depths) in enumerate(train_loader):
            images, depths = images.to(device), depths.to(device)
            optimizer.zero_grad()
            loss = depth_loss(model(images), depths)
            loss.backward()
            optimizer.step()
            train_loss += loss.item()

            # Print every 50 batches (313 batches/epoch → ~6 updates per epoch)
            if (batch_idx + 1) % 50 == 0:
                print(f"  E{epoch+1} | Batch {batch_idx+1}/{len(train_loader)} "
                      f"| loss={loss.item():.4f}")

        avg_train = train_loss / len(train_loader)

        # ── Validate ───────────────────────────────────────────────────────
        model.eval()
        val_loss = 0.0
        with torch.no_grad():
            for images, depths in test_loader:
                images, depths = images.to(device), depths.to(device)
                val_loss += depth_loss(model(images), depths).item()
        avg_val = val_loss / len(test_loader)

        scheduler.step(avg_val)
        history['train_loss'].append(avg_train)
        history['val_loss'].append(avg_val)

        print(f"\nEpoch {epoch+1}/{num_epochs} | "
              f"Train Loss: {avg_train:.4f} | Val Loss: {avg_val:.4f}")

        if avg_val < best_val_loss:
            best_val_loss = avg_val
            torch.save({
                'epoch': epoch+1,
                'model_state_dict':     model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'val_loss': best_val_loss,
            }, save_path)
            print(f"  ✓ Best model saved (val={best_val_loss:.4f})")

        print("-" * 55)

    return model, history

model, history = train_model(train_loader, test_loader, num_epochs=20)


#Plot and visualize

def plot_history(history):
    plt.figure(figsize=(10,4))
    plt.plot(history['train_loss'], label='Train', linewidth=2)
    plt.plot(history['val_loss'],   label='Val',   linewidth=2)
    plt.xlabel('Epoch'); plt.ylabel('Loss')
    plt.title('Training Curves'); plt.legend(); plt.grid(True)
    plt.savefig("/kaggle/working/training_curves.png", dpi=150)
    plt.show()

def visualize_predictions(model, dataset, n=4):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model.eval()
    mean = torch.tensor([0.485, 0.456, 0.406]).view(3,1,1)
    std  = torch.tensor([0.229, 0.224, 0.225]).view(3,1,1)

    fig, axes = plt.subplots(n, 3, figsize=(12, 4*n))
    for col, title in enumerate(['RGB Input', 'Ground Truth', 'Prediction']):
        axes[0, col].set_title(title, fontsize=13)

    for i in range(n):
        img, depth_gt = dataset[i]
        with torch.no_grad():
            pred = model(img.unsqueeze(0).to(device)).cpu().squeeze()

        axes[i,0].imshow((img*std+mean).clamp(0,1).permute(1,2,0).numpy())
        axes[i,1].imshow(depth_gt.squeeze().numpy(), cmap='plasma')
        axes[i,2].imshow(pred.numpy(),               cmap='plasma')
        for ax in axes[i]: ax.axis('off')

    plt.tight_layout()
    plt.savefig("/kaggle/working/predictions.png", dpi=150)
    plt.show()

plot_history(history)
visualize_predictions(model, test_dataset)


#Standard Depth Estimation Metrics
def compute_metrics(pred, target, min_depth=0.01, max_depth=1.0):
    """
    pred, target : tensors of shape [B, 1, H, W], values in [0,1]
    Returns dict of all standard depth estimation metrics
    """
    # Mask out invalid pixels (depth = 0 means no sensor reading)
    mask = (target > min_depth) & (target <= max_depth)
    pred   = pred[mask]
    target = target[mask]

    # Threshold accuracy δ1, δ2, δ3
    # δ1 = % of pixels where max(pred/target, target/pred) < 1.25
    ratio = torch.max(pred / target, target / pred)
    d1 = (ratio < 1.25).float().mean().item()
    d2 = (ratio < 1.25**2).float().mean().item()
    d3 = (ratio < 1.25**3).float().mean().item()

    # Error metrics
    diff    = pred - target
    abs_rel = (diff.abs() / target).mean().item()          # Mean Absolute Relative Error
    sq_rel  = ((diff**2) / target).mean().item()           # Mean Squared Relative Error
    rmse    = diff.pow(2).mean().sqrt().item()             # Root Mean Squared Error
    rmse_log = (torch.log(pred + 1e-7) -
                torch.log(target + 1e-7)).pow(2).mean().sqrt().item()  # RMSE in log space

    return {
        'δ1 (↑)':       round(d1, 4),
        'δ2 (↑)':       round(d2, 4),
        'δ3 (↑)':       round(d3, 4),
        'AbsRel (↓)':   round(abs_rel, 4),
        'SqRel (↓)':    round(sq_rel, 4),
        'RMSE (↓)':     round(rmse, 4),
        'RMSElog (↓)':  round(rmse_log, 4),
    }


#Running evaluation on full test set

def evaluate(model, test_loader):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model.eval()

    all_metrics = {
        'δ1 (↑)': [], 'δ2 (↑)': [], 'δ3 (↑)': [],
        'AbsRel (↓)': [], 'SqRel (↓)': [],
        'RMSE (↓)': [], 'RMSElog (↓)': []
    }

    with torch.no_grad():
        for images, depths in test_loader:
            images, depths = images.to(device), depths.to(device)
            preds = model(images)
            batch_metrics = compute_metrics(preds, depths)
            for k, v in batch_metrics.items():
                all_metrics[k].append(v)

    print("\n" + "="*45)
    print(f"{'EVALUATION RESULTS ON TEST SET':^45}")
    print("="*45)
    for k, v in all_metrics.items():
        avg = round(sum(v) / len(v), 4)
        print(f"  {k:<18} : {avg}")
    print("="*45)

    return {k: round(sum(v)/len(v), 4) for k, v in all_metrics.items()}

